  "pythonScripts": [
    {
      "id": "script-hx-calcs",
      "name": "Heat Exchanger Calculations",
      "description": "Real-time thermal performance calculations: heat duty, LMTD, U-value, effectiveness",
      "enabled": true,
      "runOnStartup": true,
      "code": "import math\n\n# Water properties\nCp = 1.0  # BTU/lb-degF\nrho = 8.33  # lb/gal\n\nwhile session.active:\n    # Read temperatures\n    T_hot_in = tags['TT-101']\n    T_hot_out = tags['TT-102']\n    T_cold_in = tags['TT-201']\n    T_cold_out = tags['TT-202']\n    \n    # Read flow rates\n    F_hot = tags['FT-101']  # GPM\n    F_cold = tags['FT-201']  # GPM\n    \n    # Mass flow (lb/min)\n    m_hot = F_hot * rho\n    m_cold = F_cold * rho\n    \n    # Heat duty (BTU/min)\n    Q_hot = m_hot * Cp * (T_hot_in - T_hot_out) if m_hot > 0 else 0\n    Q_cold = m_cold * Cp * (T_cold_out - T_cold_in) if m_cold > 0 else 0\n    \n    # LMTD (Log Mean Temperature Difference)\n    dT1 = T_hot_in - T_cold_out\n    dT2 = T_hot_out - T_cold_in\n    if dT1 > 0 and dT2 > 0 and abs(dT1 - dT2) > 0.1:\n        LMTD = (dT1 - dT2) / math.log(dT1 / dT2)\n    elif dT1 > 0:\n        LMTD = dT1\n    else:\n        LMTD = 0\n    \n    # Effectiveness (NTU method)\n    Q_max = min(m_hot, m_cold) * Cp * (T_hot_in - T_cold_in) if min(m_hot, m_cold) > 0 else 1\n    effectiveness = (Q_hot / Q_max * 100) if Q_max > 0 else 0\n    \n    # Publish calculated values\n    publish('HX_Q_Hot', Q_hot, units='BTU/min', description='Hot side heat duty')\n    publish('HX_Q_Cold', Q_cold, units='BTU/min', description='Cold side heat duty')\n    publish('HX_LMTD', LMTD, units='degF', description='Log mean temperature difference')\n    publish('HX_Effectiveness', effectiveness, units='%', description='Heat exchanger effectiveness')\n    publish('HX_DeltaT_Hot', T_hot_in - T_hot_out, units='degF', description='Hot side delta-T')\n    publish('HX_DeltaT_Cold', T_cold_out - T_cold_in, units='degF', description='Cold side delta-T')\n    \n    await next_scan()"
    }
  ],

  "scripts": {
    "sequences": [
      {
        "id": "seq-startup",
        "name": "System Startup",
        "description": "Safe startup procedure: open valves, start pumps, verify flow",
        "enabled": true,
        "steps": [
          {
            "id": "s1", "type": "safetyCheck", "enabled": true,
            "label": "Pre-start safety check",
            "condition": "E_Stop == false",
            "failAction": "abort",
            "failMessage": "E-Stop is engaged - cannot start"
          },
          {
            "id": "s2", "type": "message", "enabled": true,
            "label": "Startup notification",
            "message": "Starting HX test system...",
            "severity": "info",
            "pauseExecution": false
          },
          {
            "id": "s3", "type": "setOutput", "enabled": true,
            "label": "Open hot valve",
            "channel": "Valve_Hot",
            "value": true
          },
          {
            "id": "s4", "type": "setOutput", "enabled": true,
            "label": "Open cold valve",
            "channel": "Valve_Cold",
            "value": true
          },
          {
            "id": "s5", "type": "delay", "enabled": true,
            "label": "Wait for valves",
            "duration": 3000,
            "durationUnit": "ms"
          },
          {
            "id": "s6", "type": "setOutput", "enabled": true,
            "label": "Start hot pump",
            "channel": "Pump_Hot",
            "value": true
          },
          {
            "id": "s7", "type": "setOutput", "enabled": true,
            "label": "Start cold pump",
            "channel": "Pump_Cold",
            "value": true
          },
          {
            "id": "s8", "type": "wait", "enabled": true,
            "label": "Verify flow established",
            "condition": "FT-101 > 5 AND FT-201 > 5",
            "timeout": 30,
            "timeoutAction": "abort"
          },
          {
            "id": "s9", "type": "recording", "enabled": true,
            "label": "Start recording",
            "action": "start",
            "filename": "hx_test"
          },
          {
            "id": "s10", "type": "message", "enabled": true,
            "label": "Startup complete",
            "message": "System started successfully - flow verified",
            "severity": "info",
            "pauseExecution": false
          }
        ]
      },
      {
        "id": "seq-shutdown",
        "name": "System Shutdown",
        "description": "Safe shutdown: stop heater, cool down, stop pumps, close valves",
        "enabled": true,
        "steps": [
          {
            "id": "d1", "type": "message", "enabled": true,
            "label": "Shutdown start",
            "message": "Initiating system shutdown...",
            "severity": "info",
            "pauseExecution": false
          },
          {
            "id": "d2", "type": "setOutput", "enabled": true,
            "label": "Disable heater",
            "channel": "Heater_SP",
            "value": 0
          },
          {
            "id": "d3", "type": "recording", "enabled": true,
            "label": "Stop recording",
            "action": "stop"
          },
          {
            "id": "d4", "type": "wait", "enabled": true,
            "label": "Wait for cooldown",
            "condition": "TT-101 < 120",
            "timeout": 600,
            "timeoutAction": "continue"
          },
          {
            "id": "d5", "type": "setOutput", "enabled": true,
            "label": "Stop hot pump",
            "channel": "Pump_Hot",
            "value": false
          },
          {
            "id": "d6", "type": "setOutput", "enabled": true,
            "label": "Stop cold pump",
            "channel": "Pump_Cold",
            "value": false
          },
          {
            "id": "d7", "type": "delay", "enabled": true,
            "label": "Wait for pumps to stop",
            "duration": 2000,
            "durationUnit": "ms"
          },
          {
            "id": "d8", "type": "setOutput", "enabled": true,
            "label": "Close hot valve",
            "channel": "Valve_Hot",
            "value": false
          },
          {
            "id": "d9", "type": "setOutput", "enabled": true,
            "label": "Close cold valve",
            "channel": "Valve_Cold",
            "value": false
          },
          {
            "id": "d10", "type": "message", "enabled": true,
            "label": "Shutdown complete",
            "message": "System shutdown complete - all outputs safe",
            "severity": "info",
            "pauseExecution": false
          }
        ]
      },
      {
        "id": "seq-performance-test",
        "name": "Performance Test Sweep",
        "description": "Sweep through 5 temperature setpoints, record steady-state data at each",
        "enabled": true,
        "steps": [
          {
            "id": "p1", "type": "callSequence", "enabled": true,
            "label": "Run startup",
            "sequenceId": "seq-startup",
            "waitForCompletion": true
          },
          {
            "id": "p2", "type": "setVariable", "enabled": true,
            "label": "Init setpoint index",
            "variableName": "spIndex",
            "value": 0,
            "isFormula": false
          },
          {
            "id": "p3", "type": "loop", "enabled": true,
            "label": "Setpoint sweep",
            "iterations": 5,
            "loopId": "sp-sweep"
          },
          {
            "id": "p4", "type": "calculate", "enabled": true,
            "label": "Calculate setpoint",
            "expression": "100 + spIndex * 25",
            "resultVar": "currentSP"
          },
          {
            "id": "p5", "type": "ramp", "enabled": true,
            "label": "Ramp to setpoint",
            "targetChannel": "Heater_SP",
            "monitorChannel": "TT-101",
            "targetValue": 0,
            "rampRate": 5,
            "rampRateUnit": "degF/min",
            "tolerance": 3
          },
          {
            "id": "p6", "type": "message", "enabled": true,
            "label": "At setpoint",
            "message": "Reached setpoint ${currentSP}F - stabilizing for 5 minutes",
            "severity": "info",
            "pauseExecution": false
          },
          {
            "id": "p7", "type": "soak", "enabled": true,
            "label": "Stabilize",
            "duration": 300,
            "monitorChannel": "TT-101",
            "tolerance": 3
          },
          {
            "id": "p8", "type": "log", "enabled": true,
            "label": "Log steady-state",
            "message": "Steady state at SP={currentSP}F, PV={pv}F, Flow={flow}GPM",
            "level": "info",
            "values": {
              "pv": "tags['TT-101']",
              "flow": "tags['FT-101']"
            }
          },
          {
            "id": "p9", "type": "setVariable", "enabled": true,
            "label": "Next setpoint",
            "variableName": "spIndex",
            "value": "spIndex + 1",
            "isFormula": true
          },
          {
            "id": "p10", "type": "endLoop", "enabled": true,
            "label": "End sweep",
            "loopId": "sp-sweep"
          },
          {
            "id": "p11", "type": "callSequence", "enabled": true,
            "label": "Run shutdown",
            "sequenceId": "seq-shutdown",
            "waitForCompletion": true
          },
          {
            "id": "p12", "type": "message", "enabled": true,
            "label": "Test complete",
            "message": "Performance sweep test completed - 5 setpoints recorded",
            "severity": "info",
            "pauseExecution": true
          }
        ]
      }
    ]
  },

