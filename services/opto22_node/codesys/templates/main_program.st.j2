(* =========================================================================
   PROGRAM Main — ICCSFlux CODESYS Control Program

   Generated by ICCSFlux ST Code Generator
   Project: {{ project_name }}
   Generated: {{ timestamp }}
   Config Hash: {{ config_hash }}

   This program runs on the groov EPIC CODESYS runtime and provides
   deterministic PID control and safety interlocks at 1 ms scan rate.

   The Python companion process on the same EPIC communicates via
   Modbus TCP on localhost:502 to:
   - Write setpoints, tuning, and interlock commands
   - Read process values, PID outputs, and interlock status
   - Publish everything to NISystem MQTT for the dashboard

   Architecture:
     1. Read I/O from groov modules (direct hardware access)
     2. Execute PID loops (deterministic, every scan)
     3. Evaluate safety interlocks (deterministic, every scan)
     4. Apply safe state if any interlock is tripped
     5. Write outputs (with interlock blocking)
     6. Update Modbus registers for Python companion
   ========================================================================= *)

PROGRAM Main
VAR
    (* ── PID Loop Instances ───────────────────────────────────────────── *)
{% for pid in pid_loops %}
    pid_{{ pid.id }} : FB_PID_Loop;     (* {{ pid.name }}{% if pid.description %} — {{ pid.description }}{% endif %} *)
{% endfor %}

    (* ── Interlock Instances ──────────────────────────────────────────── *)
{% for ilk in interlocks %}
    ilk_{{ ilk.id }} : FB_Interlock;     (* {{ ilk.name }}{% if ilk.description %} — {{ ilk.description }}{% endif %} *)
{% endfor %}

    (* ── Safe State Manager ───────────────────────────────────────────── *)
    safeState : FB_SafeState;

    (* ── Local Variables ──────────────────────────────────────────────── *)
    scanTime_us     : DINT;              (* Scan execution time *)
    scanCounter     : DINT := 0;         (* Scan counter *)
    tStart          : TIME;              (* Scan start timestamp *)
    prevHeartbeat   : INT := 0;          (* Previous Python heartbeat *)
    heartbeatTimeout: INT := 0;          (* Heartbeat miss counter *)
{% for ch in output_channels %}
    blocked_{{ ch.name }} : BOOL;        (* TRUE if output is interlock-blocked *)
{% endfor %}
END_VAR

(* ═══════════════════════════════════════════════════════════════════════ *)
(*  SCAN START                                                            *)
(* ═══════════════════════════════════════════════════════════════════════ *)
tStart := TIME();
scanCounter := scanCounter + 1;

(* ═══════════════════════════════════════════════════════════════════════ *)
(*  1. READ I/O — groov module direct access                              *)
(* ═══════════════════════════════════════════════════════════════════════ *)
{% for ch in input_channels %}
GVL_Registers.PV_{{ ch.name }} := {{ ch.io_path }};    (* {{ ch.description }} *)
{% endfor %}

(* ═══════════════════════════════════════════════════════════════════════ *)
(*  2. PID EXECUTION — deterministic every scan                           *)
(* ═══════════════════════════════════════════════════════════════════════ *)
{% for pid in pid_loops %}
pid_{{ pid.id }}(
    PV          := GVL_Registers.PV_{{ pid.pv_channel }},
    SP          := GVL_Registers.SP_{{ pid.id }},
    Kp          := GVL_Registers.Kp_{{ pid.id }},
    Ki          := GVL_Registers.Ki_{{ pid.id }},
    Kd          := GVL_Registers.Kd_{{ pid.id }},
    dt          := 0.001,   (* 1 ms task cycle *)
    OutMin      := {{ pid.output_min }},
    OutMax      := {{ pid.output_max }},
    Enable      := TRUE,
    ManualMode  := FALSE,
    ReverseAction := {{ 'TRUE' if pid.reverse_action else 'FALSE' }},
    Deadband    := {{ pid.deadband }}
);
GVL_Registers.CV_{{ pid.id }} := pid_{{ pid.id }}.CV;
{% endfor %}

(* ═══════════════════════════════════════════════════════════════════════ *)
(*  3. SAFETY INTERLOCKS — deterministic every scan                       *)
(* ═══════════════════════════════════════════════════════════════════════ *)
{% for ilk in interlocks %}
ilk_{{ ilk.id }}(
    ConditionOK := {{ ilk.condition_st }},
    ArmCommand  := GVL_Registers.Arm_{{ ilk.id }},
    DisarmCommand := FALSE,
    ResetCommand := FALSE,
    BypassActive := GVL_Registers.Bypass_{{ ilk.id }}
);
GVL_Registers.State_{{ ilk.id }} := ilk_{{ ilk.id }}.State;
GVL_Registers.Trips_{{ ilk.id }} := INT_TO_INT(ilk_{{ ilk.id }}.TripCount);
GVL_Registers.Tripped_{{ ilk.id }} := ilk_{{ ilk.id }}.Tripped;
{% endfor %}

(* ═══════════════════════════════════════════════════════════════════════ *)
(*  4. SAFE STATE — apply if any interlock tripped or E-stop              *)
(* ═══════════════════════════════════════════════════════════════════════ *)
safeState(
    ApplyAll := FALSE,
    EStopActive := (GVL_Registers.SYS_EStop = 1)
);

(* Determine which outputs are blocked by interlocks *)
{% for ch in output_channels %}
blocked_{{ ch.name }} := safeState.SafeStateActive
{%- for ilk in interlocks %}
{%- if ch.name in ilk.controlled_outputs %}
    OR ilk_{{ ilk.id }}.ApplySafeState
{%- endif %}
{%- endfor %};
{% endfor %}

(* ═══════════════════════════════════════════════════════════════════════ *)
(*  5. WRITE OUTPUTS — with interlock blocking                            *)
(* ═══════════════════════════════════════════════════════════════════════ *)
{% for ch in output_channels %}
IF blocked_{{ ch.name }} THEN
    {{ ch.io_path }} := {{ ch.safe_value }};    (* Safe value for {{ ch.name }} *)
ELSE
    {{ ch.io_path }} := {% if ch.pid_cv %}GVL_Registers.CV_{{ ch.pid_cv }}{% else %}GVL_Registers.OVR_{{ ch.name }}{% endif %};
END_IF
{% endfor %}

(* ═══════════════════════════════════════════════════════════════════════ *)
(*  6. PYTHON HEARTBEAT WATCHDOG                                          *)
(* ═══════════════════════════════════════════════════════════════════════ *)
(* If Python stops incrementing its heartbeat for 5 seconds, apply safe state *)
IF GVL_Registers.SYS_Heartbeat <> prevHeartbeat THEN
    prevHeartbeat := GVL_Registers.SYS_Heartbeat;
    heartbeatTimeout := 0;
ELSE
    heartbeatTimeout := heartbeatTimeout + 1;
    IF heartbeatTimeout > 5000 THEN   (* 5000 scans × 1 ms = 5 seconds *)
        safeState.ApplyAll := TRUE;   (* Python companion lost — go safe *)
    END_IF
END_IF

(* ═══════════════════════════════════════════════════════════════════════ *)
(*  7. SYSTEM STATUS — for Python to read via Modbus                      *)
(* ═══════════════════════════════════════════════════════════════════════ *)
scanTime_us := TIME_TO_DINT(TIME() - tStart);
GVL_Registers.SYS_ScanTime_us := scanTime_us;
GVL_Registers.SYS_Watchdog := GVL_Registers.SYS_Watchdog + 1;
IF GVL_Registers.SYS_Watchdog > 32000 THEN
    GVL_Registers.SYS_Watchdog := 0;
END_IF

END_PROGRAM
