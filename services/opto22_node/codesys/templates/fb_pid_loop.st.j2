(* =========================================================================
   FB_PID_Loop — PID Controller Function Block

   Generated by ICCSFlux ST Code Generator
   Matches the Python PID algorithm in pid_engine.py exactly.

   Features:
   - Auto / Manual mode with bumpless transfer
   - Anti-windup (integral clamping)
   - Derivative-on-PV (eliminates setpoint kick)
   - Output rate limiting
   - Configurable output range
   ========================================================================= *)

FUNCTION_BLOCK FB_PID_Loop
VAR_INPUT
    PV          : REAL;             (* Process Variable — measured value *)
    SP          : REAL;             (* Setpoint — desired value *)
    Kp          : REAL := 1.0;      (* Proportional gain *)
    Ki          : REAL := 0.1;      (* Integral gain (per second) *)
    Kd          : REAL := 0.0;      (* Derivative gain *)
    dt          : REAL := 0.001;    (* Scan cycle time in seconds *)
    OutMin      : REAL := 0.0;      (* Minimum output *)
    OutMax      : REAL := 100.0;    (* Maximum output *)
    Enable      : BOOL := TRUE;     (* Enable PID calculation *)
    ManualMode  : BOOL := FALSE;    (* TRUE = manual output, FALSE = auto PID *)
    ManualOutput: REAL := 0.0;      (* Output value when in manual mode *)
    ReverseAction: BOOL := FALSE;   (* TRUE = reverse-acting (cooling) *)
    Deadband    : REAL := 0.0;      (* Error deadband *)
END_VAR

VAR_OUTPUT
    CV          : REAL;             (* Control Variable — output to actuator *)
    Error       : REAL;             (* Current error (SP - PV) *)
    PTerm       : REAL;             (* Proportional contribution *)
    ITerm       : REAL;             (* Integral contribution *)
    DTerm       : REAL;             (* Derivative contribution *)
    Active      : BOOL;            (* TRUE when loop is running *)
END_VAR

VAR
    integral    : REAL := 0.0;      (* Accumulated integral *)
    lastPV      : REAL := 0.0;      (* Previous PV for derivative-on-PV *)
    lastOutput  : REAL := 0.0;      (* Previous output for bumpless transfer *)
    firstScan   : BOOL := TRUE;     (* First scan flag *)
    wasManual   : BOOL := FALSE;    (* Previous manual mode state *)
    rawOutput   : REAL;             (* Pre-clamped output *)
    iContrib    : REAL;             (* Integral contribution this scan *)
END_VAR

(* ── Main PID Algorithm ─────────────────────────────────────────────── *)

IF NOT Enable THEN
    Active := FALSE;
    RETURN;
END_IF

Active := TRUE;

(* ── Manual Mode ──────────────────────────────────────────────────── *)
IF ManualMode THEN
    CV := ManualOutput;
    (* Clamp manual output *)
    IF CV > OutMax THEN CV := OutMax; END_IF
    IF CV < OutMin THEN CV := OutMin; END_IF
    lastPV := PV;
    lastOutput := CV;
    wasManual := TRUE;
    RETURN;
END_IF

(* ── Bumpless Transfer: Manual → Auto ────────────────────────────── *)
IF wasManual THEN
    (* Initialize integral to match current output minus P and D terms *)
    integral := lastOutput;
    firstScan := TRUE;  (* Recalculate from current state *)
    wasManual := FALSE;
END_IF

(* ── Error Calculation ────────────────────────────────────────────── *)
Error := SP - PV;
IF ReverseAction THEN
    Error := -Error;
END_IF

(* Apply deadband *)
IF ABS(Error) < Deadband THEN
    Error := 0.0;
END_IF

(* ── First Scan Initialization ────────────────────────────────────── *)
IF firstScan THEN
    lastPV := PV;
    firstScan := FALSE;
    (* Keep existing integral (set during bumpless transfer or default 0) *)
END_IF

(* ── Proportional Term ────────────────────────────────────────────── *)
PTerm := Kp * Error;

(* ── Integral Term (with anti-windup clamping) ────────────────────── *)
IF Ki > 0.0 AND dt > 0.0 THEN
    iContrib := Ki * Error * dt;

    (* Anti-windup: don't accumulate if output is saturated *)
    rawOutput := PTerm + integral + iContrib;
    IF (rawOutput >= OutMax AND iContrib > 0.0) OR
       (rawOutput <= OutMin AND iContrib < 0.0) THEN
        (* Output saturated in same direction — clamp integral *)
    ELSE
        integral := integral + iContrib;
    END_IF
END_IF
ITerm := integral;

(* ── Derivative Term (derivative-on-PV) ───────────────────────────── *)
IF Kd > 0.0 AND dt > 0.0 THEN
    (* Derivative on PV avoids setpoint kick *)
    DTerm := Kd * (-(PV - lastPV) / dt);
ELSE
    DTerm := 0.0;
END_IF

(* ── Output Calculation + Clamping ────────────────────────────────── *)
CV := PTerm + ITerm + DTerm;

IF CV > OutMax THEN
    CV := OutMax;
ELSIF CV < OutMin THEN
    CV := OutMin;
END_IF

(* ── Save State ───────────────────────────────────────────────────── *)
lastPV := PV;
lastOutput := CV;

END_FUNCTION_BLOCK
