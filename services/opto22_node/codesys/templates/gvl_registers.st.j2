(* =========================================================================
   GVL_Registers — Global Variable List for Modbus Register Mapping

   Generated by ICCSFlux ST Code Generator
   Project: {{ project_name }}
   Generated: {{ timestamp }}
   Config Hash: {{ config_hash }}

   This GVL maps CODESYS variables to Modbus registers for communication
   with the Python companion process over localhost Modbus TCP (port 502).

   In CODESYS, map these variables to the Modbus Slave device I/O using
   the "Modbus TCP Slave" device configuration.

   Register Convention:
     Holding Registers (4xxxx) — Python writes, CODESYS reads
     Input Registers (3xxxx)  — CODESYS writes, Python reads
     Coils (0xxxx)            — Python writes single bits
     Discrete Inputs (1xxxx)  — CODESYS writes single bits
   ========================================================================= *)

{VAR_GLOBAL}

    (* ── PID Setpoints (Holding Registers — Python → CODESYS) ────────── *)
{% for pid in pid_loops %}
    SP_{{ pid.id }}         AT %QW{{ pid.sp_offset }}  : REAL;      (* Setpoint for {{ pid.name }} [{{ pid.sp_address }}] *)
{% endfor %}

    (* ── PID Tuning (Holding Registers — Python → CODESYS) ───────────── *)
{% for pid in pid_loops %}
    Kp_{{ pid.id }}         AT %QW{{ pid.kp_offset }}  : REAL := {{ pid.kp }};  (* P gain [{{ pid.kp_address }}] *)
    Ki_{{ pid.id }}         AT %QW{{ pid.ki_offset }}  : REAL := {{ pid.ki }};  (* I gain [{{ pid.ki_address }}] *)
    Kd_{{ pid.id }}         AT %QW{{ pid.kd_offset }}  : REAL := {{ pid.kd }};  (* D gain [{{ pid.kd_address }}] *)
{% endfor %}

    (* ── PID Outputs (Input Registers — CODESYS → Python) ────────────── *)
{% for pid in pid_loops %}
    CV_{{ pid.id }}         AT %IW{{ pid.cv_offset }}  : REAL;      (* Control output [{{ pid.cv_address }}] *)
{% endfor %}

    (* ── Process Values (Input Registers — CODESYS → Python) ─────────── *)
{% for ch in channels %}
    PV_{{ ch.name }}         AT %IW{{ ch.pv_offset }}  : REAL;        (* {{ ch.description }} [{{ ch.pv_address }}] *)
{% endfor %}

    (* ── Interlock Commands (Coils — Python → CODESYS) ───────────────── *)
{% for ilk in interlocks %}
    Arm_{{ ilk.id }}         AT %QX{{ ilk.arm_byte }}.{{ ilk.arm_bit }}  : BOOL;   (* Arm interlock [coil {{ ilk.arm_coil }}] *)
    Bypass_{{ ilk.id }}      AT %QX{{ ilk.bypass_byte }}.{{ ilk.bypass_bit }}  : BOOL;  (* Bypass [coil {{ ilk.bypass_coil }}] *)
{% endfor %}

    (* ── Interlock Status (Input Registers — CODESYS → Python) ───────── *)
{% for ilk in interlocks %}
    State_{{ ilk.id }}       AT %IW{{ ilk.status_offset }}  : INT;     (* 0=SAFE,1=ARMED,2=TRIPPED [{{ ilk.status_address }}] *)
    Trips_{{ ilk.id }}       AT %IW{{ ilk.trips_offset }}  : INT;      (* Trip count [{{ ilk.trip_count_address }}] *)
{% endfor %}

    (* ── Interlock Tripped Flags (Discrete Inputs — CODESYS → Python) ── *)
{% for ilk in interlocks %}
    Tripped_{{ ilk.id }}     AT %IX{{ ilk.tripped_byte }}.{{ ilk.tripped_bit }}  : BOOL;  (* [disc {{ ilk.tripped_discrete }}] *)
{% endfor %}

    (* ── Output Overrides (Holding Registers — Python → CODESYS) ─────── *)
{% for out in outputs %}
    OVR_{{ out.name }}       AT %QW{{ out.override_offset }}  : REAL;  (* Override value [{{ out.override_address }}] *)
{% endfor %}

    (* ── System Commands (Holding Registers — Python → CODESYS) ──────── *)
    SYS_EStop                AT %QW{{ sys_cmd_offset }}  : INT;        (* 0=normal, 1=E-stop *)
    SYS_Mode                 AT %QW{{ sys_cmd_offset + 1 }}  : INT;    (* 0=auto, 1=manual, 2=safe *)
    SYS_Heartbeat            AT %QW{{ sys_cmd_offset + 2 }}  : INT;    (* Python heartbeat counter *)
    SYS_Acquire              AT %QW{{ sys_cmd_offset + 3 }}  : INT;    (* 0=stop, 1=run *)

    (* ── System Status (Input Registers — CODESYS → Python) ──────────── *)
    SYS_ScanTime_us          AT %IW{{ sys_status_offset }}  : DINT;    (* Last scan time (microseconds) *)
    SYS_ErrorCount           AT %IW{{ sys_status_offset + 2 }}  : INT; (* Cumulative errors *)
    SYS_Watchdog             AT %IW{{ sys_status_offset + 3 }}  : INT; (* CODESYS watchdog counter *)

END_VAR
