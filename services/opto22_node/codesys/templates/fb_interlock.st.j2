(* =========================================================================
   FB_Interlock — IEC 61511 Safety Interlock Function Block

   Generated by ICCSFlux ST Code Generator
   Matches the Python latch state machine in safety.py.

   Latch States (IEC 61511):
     0 = SAFE      — Interlock not armed, conditions not monitored
     1 = ARMED     — Monitoring conditions, will trip if condition fails
     2 = TRIPPED   — Condition failed while armed, safe state applied

   State Transitions:
     SAFE → ARMED     : ArmCommand rising edge
     ARMED → TRIPPED  : ConditionOK = FALSE (condition failed)
     TRIPPED → ARMED  : ResetCommand rising edge (re-arms after trip)
     ARMED → SAFE     : DisarmCommand rising edge
     TRIPPED → SAFE   : DisarmCommand rising edge

   Bypass:
     When BypassActive = TRUE, the interlock does NOT trip even if
     ConditionOK = FALSE. Used for maintenance and commissioning.
     Bypass does NOT change the state — it only suppresses tripping.
   ========================================================================= *)

FUNCTION_BLOCK FB_Interlock
VAR_INPUT
    ConditionOK     : BOOL;         (* TRUE = safe condition met, FALSE = trip *)
    ArmCommand      : BOOL;         (* Rising edge arms the interlock *)
    DisarmCommand   : BOOL;         (* Rising edge disarms (returns to SAFE) *)
    ResetCommand    : BOOL;         (* Rising edge resets trip (TRIPPED → ARMED) *)
    BypassActive    : BOOL;         (* TRUE = suppress tripping (maintenance) *)
END_VAR

VAR_OUTPUT
    State           : INT := 0;     (* 0=SAFE, 1=ARMED, 2=TRIPPED *)
    Tripped         : BOOL;         (* TRUE when State = TRIPPED *)
    Armed           : BOOL;         (* TRUE when State = ARMED *)
    Bypassed        : BOOL;         (* Echo of BypassActive for status *)
    TripCount       : DINT := 0;    (* Cumulative trip count *)
    DemandCount     : DINT := 0;    (* Condition fail count (demand on safety) *)
    ApplySafeState  : BOOL;         (* TRUE = outputs should be set to safe values *)
END_VAR

VAR
    prevArmCmd      : BOOL := FALSE;
    prevDisarmCmd   : BOOL := FALSE;
    prevResetCmd    : BOOL := FALSE;
    prevConditionOK : BOOL := TRUE;
END_VAR

(* ── Edge Detection ───────────────────────────────────────────────── *)
VAR
    armEdge         : BOOL;
    disarmEdge      : BOOL;
    resetEdge       : BOOL;
    conditionFell   : BOOL;         (* Rising edge of NOT ConditionOK *)
END_VAR

armEdge := ArmCommand AND NOT prevArmCmd;
disarmEdge := DisarmCommand AND NOT prevDisarmCmd;
resetEdge := ResetCommand AND NOT prevResetCmd;
conditionFell := NOT ConditionOK AND prevConditionOK;

(* ── Demand Counting ──────────────────────────────────────────────── *)
(* Count each time the condition transitions from OK to NOT OK *)
IF conditionFell THEN
    DemandCount := DemandCount + 1;
END_IF

(* ── State Machine ────────────────────────────────────────────────── *)
CASE State OF

    0: (* SAFE — not monitoring *)
        Tripped := FALSE;
        Armed := FALSE;
        ApplySafeState := FALSE;

        IF armEdge THEN
            State := 1;  (* → ARMED *)
        END_IF

    1: (* ARMED — monitoring conditions *)
        Tripped := FALSE;
        Armed := TRUE;
        ApplySafeState := FALSE;

        IF disarmEdge THEN
            State := 0;  (* → SAFE *)
        ELSIF NOT ConditionOK AND NOT BypassActive THEN
            State := 2;  (* → TRIPPED *)
            TripCount := TripCount + 1;
        END_IF

    2: (* TRIPPED — safe state applied *)
        Tripped := TRUE;
        Armed := FALSE;
        ApplySafeState := TRUE;

        IF disarmEdge THEN
            State := 0;  (* → SAFE *)
            ApplySafeState := FALSE;
        ELSIF resetEdge AND ConditionOK THEN
            State := 1;  (* → ARMED (re-arm after reset) *)
            ApplySafeState := FALSE;
        END_IF

END_CASE

Bypassed := BypassActive;

(* ── Save Previous States ─────────────────────────────────────────── *)
prevArmCmd := ArmCommand;
prevDisarmCmd := DisarmCommand;
prevResetCmd := ResetCommand;
prevConditionOK := ConditionOK;

END_FUNCTION_BLOCK
