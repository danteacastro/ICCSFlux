      {
        "name": "H2S Pipeline Spec Violation",
        "condition": "AT-302 > 4",
        "action": "h2s-shutdown",
        "delay_ms": 5000,
        "description": "Blocks pipeline injection if treated gas H2S exceeds 4 ppm (FERC tariff limit)"
      },
      {
        "name": "Low CH4 Purity Block",
        "condition": "AT-301 < 95",
        "action": "low-purity-block",
        "delay_ms": 10000,
        "description": "Blocks pipeline injection if CH4 purity drops below 95% (utility interconnect agreement)"
      },
      {
        "name": "Compressor Overtemperature",
        "condition": "TT-201 > 150 OR TT-202 > 160",
        "action": "compressor-overtemp",
        "delay_ms": 3000,
        "description": "Shuts down compressor if discharge temperature exceeds safe limits"
      },
      {
        "name": "Gas Detection Emergency Shutdown",
        "condition": "GD-101 == true OR GD-102 == true",
        "action": "gas-detection-shutdown",
        "delay_ms": 0,
        "description": "Immediate station shutdown on combustible gas detection (>25% LEL)"
      },
      {
        "name": "CNG Storage Overpressure",
        "condition": "PT-501 > 260",
        "action": "cng-overpressure",
        "delay_ms": 2000,
        "description": "Closes CNG dispenser valve and stops compressor if storage exceeds 260 bar"
      },
      {
        "name": "Compressor Lube Oil Failure",
        "condition": "PSL-201 == true AND K-201 == true",
        "action": "compressor-oil-shutdown",
        "delay_ms": 3000,
        "description": "Trips compressor if lube oil pressure switch indicates low pressure while running"
      },
      {
        "name": "Fire Detection Shutdown",
        "condition": "FD-101 == true",
        "action": "fire-shutdown",
        "delay_ms": 0,
        "description": "Immediate ESD on flame detection - isolates gas, opens vent to flare"
      },
      {
        "name": "Station Master ESD",
        "condition": "ESDPB-001 == true",
        "action": "emergency-shutdown",
        "delay_ms": 0,
        "description": "Manual emergency shutdown - stops all equipment, isolates gas, activates alarm"
      },
      {
        "name": "CNG Dispenser ESD",
        "condition": "ESDPB-002 == true OR ZS-501 == false",
        "action": "dispenser-shutdown",
        "delay_ms": 0,
        "description": "Shuts CNG dispenser on local ESD or breakaway coupling disconnect"
      },
      {
        "name": "Biogas Supply Loss",
        "condition": "FT-101 < 20 AND K-201 == true",
        "action": "compressor-suction-loss",
        "delay_ms": 15000,
        "description": "Shuts compressor if inlet flow drops below minimum (prevents running dry)"
      }
