    "pythonScripts": [
      {
        "id": "script-gas-quality",
        "name": "Gas Quality Monitor",
        "code": "# Gas Quality Monitor\n# Tracks pipeline gas quality metrics and publishes derived values\n# Uses: SignalFilter, LookupTable, publish()\n\nif 'ch4_filt' not in vars:\n    vars['ch4_filt'] = SignalFilter(tau=30.0, dt=1.0)\n    vars['h2s_filt'] = SignalFilter(tau=10.0, dt=1.0)\n    vars['wobbe_filt'] = SignalFilter(tau=30.0, dt=1.0)\n    # CH4 % -> BTU/SCF heating value (approximate)\n    vars['btu_table'] = LookupTable([\n        (90, 910), (92, 930), (94, 950),\n        (96, 970), (97, 985), (98, 1000),\n        (99, 1010), (100, 1020)\n    ])\n\n# Smooth raw analyzer readings\nch4_purity = vars['ch4_filt'].update(tags['AT-301'])\nh2s_content = vars['h2s_filt'].update(tags['AT-302'])\nwobbe = vars['wobbe_filt'].update(tags['AT-401'])\n\n# Calculate heating value from CH4 purity\nbtu_value = vars['btu_table'](ch4_purity)\n\n# Gas recovery efficiency (treated flow / inlet flow)\ninlet_flow = tags['FT-101']\ntreated_flow = tags['FT-301']\nif inlet_flow > 10:\n    recovery_pct = (treated_flow / inlet_flow) * 100\nelse:\n    recovery_pct = 0\n\n# Pipeline specification compliance\n# FERC/utility specs: CH4 > 95%, H2S < 4 ppm, 970 < Wobbe < 1150\nspec_pass = 1 if (ch4_purity >= 95 and h2s_content < 4 and 970 <= wobbe <= 1150) else 0\n\npublish('CALC-BTU', btu_value, units='BTU/SCF')\npublish('CALC-Recovery', recovery_pct, units='%')\npublish('CALC-PipelineSpec', spec_pass)\npublish('CALC-CH4Smooth', ch4_purity, units='%')\npublish('CALC-H2SSmooth', h2s_content, units='ppm')\n",
        "description": "Calculates BTU content, gas recovery efficiency, and pipeline spec compliance from analyzer readings",
        "runMode": "acquisition",
        "enabled": true
      },
      {
        "id": "script-compressor-health",
        "name": "Compressor Health Monitor",
        "code": "# Compressor Health Monitor\n# Tracks compression ratio, efficiency, and predictive maintenance\n# Uses: TrendLine, RollingStats, SignalFilter, publish()\n\nif 'comp_trend' not in vars:\n    vars['comp_trend'] = TrendLine(window=600)  # 10 min window\n    vars['vib_stats'] = RollingStats(window=300)  # 5 min stats\n    vars['discharge_filt'] = SignalFilter(tau=5.0, dt=1.0)\n    vars['runtime'] = Accumulator(mode='time')  # Track runtime hours\n\ntrend = vars['comp_trend']\nvib_stats = vars['vib_stats']\n\n# Compression ratio (Stage 2 discharge / Stage 1 suction)\n# PT-101 is in kPa, PT-202 is in bar; convert to same units\nsuction_bar = tags['PT-101'] / 100.0  # kPa to bar\ndischarge_bar = tags['PT-202']\nif suction_bar > 0.5:\n    comp_ratio = discharge_bar / suction_bar\nelse:\n    comp_ratio = 0\n\n# Polytropic efficiency estimate (simplified)\n# Using temperature ratio vs pressure ratio\nt_suction = tags['TT-101'] + 273.15  # Convert to Kelvin\nt_discharge = tags['TT-202'] + 273.15\nif t_suction > 0 and comp_ratio > 1:\n    ideal_t_ratio = comp_ratio ** 0.28  # k-1/k for methane ~0.28\n    actual_t_ratio = t_discharge / t_suction\n    if actual_t_ratio > 1:\n        poly_eff = ((ideal_t_ratio - 1) / (actual_t_ratio - 1)) * 100\n        poly_eff = max(0, min(100, poly_eff))\n    else:\n        poly_eff = 0\nelse:\n    poly_eff = 0\n\n# Vibration trending\nvib_rms = (tags['VT-201'] + tags['VT-202']) / 2\nvib_stats.update(vib_rms)\ntrend.update(vib_rms)\ntrend_result = trend.get_result() if hasattr(trend, 'get_result') else {'slope': 0}\n\n# Track compressor runtime\nif tags['K-201'] == 1:\n    vars['runtime'].update(1)\n\npublish('CALC-CompRatio', comp_ratio)\npublish('CALC-PolyEff', poly_eff, units='%')\npublish('CALC-VibAvg', vib_rms, units='mm/s')\npublish('CALC-VibStdDev', vib_stats.std if hasattr(vib_stats, 'std') else 0, units='mm/s')\npublish('CALC-Runtime', vars['runtime'].value / 3600, units='hrs')\n",
        "description": "Monitors compression ratio, polytropic efficiency, vibration trends, and runtime hours",
        "runMode": "acquisition",
        "enabled": true
      },
      {
        "id": "script-production-totals",
        "name": "RNG Production Totals",
        "code": "# RNG Production Totals\n# Tracks daily and cumulative RNG production volumes\n# Uses: Accumulator, Counter, publish()\n\nif 'daily_vol' not in vars:\n    vars['daily_vol'] = Accumulator(mode='cumulative')  # Daily SCFM -> SCF\n    vars['total_vol'] = Accumulator(mode='cumulative')  # Lifetime total\n    vars['cng_dispensed'] = Accumulator(mode='cumulative')  # CNG dispensed\n    vars['fill_counter'] = Counter()  # CNG fill count\n    vars['cng_was_flowing'] = False\n    vars['last_hour'] = -1\n\n# Accumulate pipeline injection flow (SCFM -> SCF at 1 Hz)\npipeline_flow = tags['FT-401']\nif pipeline_flow > 1:  # Only count meaningful flow\n    scf_per_sample = pipeline_flow / 60.0  # SCFM to SCF/second\n    vars['daily_vol'].update(scf_per_sample)\n    vars['total_vol'].update(scf_per_sample)\n\n# Track CNG dispensing\ncng_flow = tags['FT-501']  # GGE/min\nif cng_flow > 0.1:\n    gge_per_sample = cng_flow / 60.0  # GGE/min to GGE/second\n    vars['cng_dispensed'].update(gge_per_sample)\n    if not vars['cng_was_flowing']:\n        vars['fill_counter'].increment()  # New fill started\n    vars['cng_was_flowing'] = True\nelse:\n    vars['cng_was_flowing'] = False\n\n# Convert SCF to therms (1 therm = 100,000 BTU, ~100 SCF of RNG)\ndaily_scf = vars['daily_vol'].value\ndaily_therms = daily_scf / 100.0\ndaily_mmbtu = daily_scf * 1010 / 1e6  # Assuming 1010 BTU/SCF\n\n# Hourly midnight reset check (simplified)\nimport_time = now()\ncurrent_hour = int(import_time) % 86400 // 3600\nif current_hour == 0 and vars['last_hour'] != 0:\n    vars['daily_vol'].reset()\nvars['last_hour'] = current_hour\n\npublish('CALC-DailySCF', daily_scf, units='SCF')\npublish('CALC-DailyTherms', daily_therms, units='therms')\npublish('CALC-DailyMMBTU', daily_mmbtu, units='MMBTU')\npublish('CALC-TotalSCF', vars['total_vol'].value, units='SCF')\npublish('CALC-CNGDispensed', vars['cng_dispensed'].value, units='GGE')\npublish('CALC-CNGFills', vars['fill_counter'].count)\n",
        "description": "Tracks daily/cumulative RNG production volumes in SCF, therms, MMBTU, and CNG dispensing totals in GGE",
        "runMode": "acquisition",
        "enabled": true
      },
      {
        "id": "script-amine-monitor",
        "name": "Amine System Performance",
        "code": "# Amine System Performance Monitor\n# Tracks H2S/CO2 removal efficiency and amine health\n# Uses: SignalFilter, RollingStats, publish()\n\nif 'co2_in_filt' not in vars:\n    vars['co2_in_filt'] = SignalFilter(tau=30.0, dt=1.0)\n    vars['h2s_in_filt'] = SignalFilter(tau=30.0, dt=1.0)\n    vars['h2s_out_filt'] = SignalFilter(tau=10.0, dt=1.0)\n    vars['reboiler_stats'] = RollingStats(window=300)\n\n# Inlet gas composition (raw biogas)\nco2_inlet = vars['co2_in_filt'].update(tags['AT-102'])\nh2s_inlet = vars['h2s_in_filt'].update(tags['AT-103'])\n\n# Outlet gas composition (treated)\nch4_outlet = tags['AT-301']\nh2s_outlet = vars['h2s_out_filt'].update(tags['AT-302'])\n\n# CO2 removal efficiency\n# Inlet CO2 -> residual CO2 = 100 - CH4 (approx, ignoring trace gases)\nco2_outlet = 100 - ch4_outlet\nif co2_inlet > 1:\n    co2_removal = ((co2_inlet - co2_outlet) / co2_inlet) * 100\nelse:\n    co2_removal = 0\n\n# H2S removal efficiency\nif h2s_inlet > 10:\n    h2s_removal = ((h2s_inlet - h2s_outlet) / h2s_inlet) * 100\nelse:\n    h2s_removal = 0\n\n# Reboiler temperature stability (amine regeneration quality)\nvars['reboiler_stats'].update(tags['TT-302'])\nreboiler_stable = 1 if vars['reboiler_stats'].std < 3.0 else 0\n\n# Amine circulation rate indicator\namine_valve = tags['AO-CV-301']  # Control valve %\n\npublish('CALC-CO2Removal', co2_removal, units='%')\npublish('CALC-H2SRemoval', h2s_removal, units='%')\npublish('CALC-ReboilerStable', reboiler_stable)\npublish('CALC-AmineValve', amine_valve, units='%')\n",
        "description": "Monitors amine scrubber CO2/H2S removal efficiency and regenerator stability",
        "runMode": "acquisition",
        "enabled": true
      }
    ]
