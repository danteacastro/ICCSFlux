  "scripts": {
    "calculatedParams": [],
    "sequences": [
      {
        "id": "seq-startup",
        "name": "System Startup Sequence",
        "description": "Controlled startup of cooling system",
        "enabled": true,
        "steps": [
          {
            "action": "set",
            "channel": "P-101",
            "value": true,
            "description": "Start primary pump"
          },
          {
            "action": "wait",
            "duration": 5,
            "description": "Wait for flow to establish"
          },
          {
            "action": "set",
            "channel": "XV-101",
            "value": true,
            "description": "Open Pod A valve"
          },
          {
            "action": "set",
            "channel": "XV-201",
            "value": true,
            "description": "Open Pod B valve"
          },
          {
            "action": "wait",
            "duration": 3,
            "description": "Wait for valves"
          },
          {
            "action": "set",
            "channel": "CH-101",
            "value": true,
            "description": "Start chiller"
          },
          {
            "action": "set",
            "channel": "CT-FAN",
            "value": true,
            "description": "Start cooling tower fan"
          }
        ]
      },
      {
        "id": "seq-shutdown",
        "name": "System Shutdown Sequence",
        "description": "Controlled shutdown of cooling system",
        "enabled": true,
        "steps": [
          {
            "action": "set",
            "channel": "CH-101",
            "value": false,
            "description": "Stop chiller"
          },
          {
            "action": "wait",
            "duration": 30,
            "description": "Coast-down period"
          },
          {
            "action": "set",
            "channel": "CT-FAN",
            "value": false,
            "description": "Stop cooling tower"
          },
          {
            "action": "set",
            "channel": "XV-101",
            "value": false,
            "description": "Close Pod A valve"
          },
          {
            "action": "set",
            "channel": "XV-201",
            "value": false,
            "description": "Close Pod B valve"
          },
          {
            "action": "wait",
            "duration": 5,
            "description": "Wait for valves"
          },
          {
            "action": "set",
            "channel": "P-101",
            "value": false,
            "description": "Stop pump"
          }
        ]
      }
    ],
