            "min": 0, "max": 100,
            "unit": "% LEL",
            "thresholds": [
              { "value": 10, "color": "#fbbf24" },
              { "value": 25, "color": "#ef4444" }
            ]
          }
        },
        {
          "id": "gauge-h2-2",
          "type": "gauge",
          "x": 6, "y": 2, "w": 2, "h": 2,
          "config": {
            "channel": "H2_Ambient_2",
            "label": "Supply Area",
            "min": 0, "max": 100,
            "unit": "% LEL",
            "thresholds": [
              { "value": 10, "color": "#fbbf24" },
              { "value": 25, "color": "#ef4444" }
            ]
          }
        },
        {
          "id": "title-flame",
          "type": "title",
          "x": 8, "y": 1, "w": 2, "h": 1,
          "config": { "label": "FLAME", "fontSize": "medium" }
        },
        {
          "id": "gauge-flame",
          "type": "gauge",
          "x": 8, "y": 2, "w": 2, "h": 2,
          "config": {
            "channel": "Flame_Signal",
            "label": "UV Signal",
            "min": 0, "max": 100,
            "unit": "%",
            "thresholds": [
              { "value": 20, "color": "#ef4444" },
              { "value": 50, "color": "#fbbf24" }
