        },
        {
          "id": "led-estop",
          "type": "led",
          "x": 4, "y": 6, "w": 1, "h": 1,
          "config": { "channel": "E_Stop_OK", "label": "E-Stop", "onColor": "#22c55e" }
        },
        {
          "id": "led-door",
          "type": "led",
          "x": 5, "y": 6, "w": 1, "h": 1,
          "config": { "channel": "Door_Interlock_OK", "label": "Door", "onColor": "#22c55e" }
        },
        {
          "id": "title-valves",
          "type": "title",
          "x": 6, "y": 5, "w": 3, "h": 1,
          "config": { "label": "VALVE STATUS", "fontSize": "medium" }
        },
        {
          "id": "led-pilot",
          "type": "led",
          "x": 6, "y": 6, "w": 1, "h": 1,
          "config": { "channel": "Pilot_Valve", "label": "Pilot", "onColor": "#60a5fa" }
        },
        {
          "id": "led-main",
          "type": "led",
          "x": 7, "y": 6, "w": 1, "h": 1,
          "config": { "channel": "Main_Gas_Valve", "label": "Main NG", "onColor": "#60a5fa" }
        },
        {
          "id": "led-h2",
          "type": "led",
          "x": 8, "y": 6, "w": 1, "h": 1,
          "config": { "channel": "H2_Shutoff_Valve", "label": "H2 Valve", "onColor": "#22d3ee" }
        },
        {
          "id": "led-blower",
          "type": "led",
          "x": 9, "y": 6, "w": 1, "h": 1,
          "config": { "channel": "Blower_Start", "label": "Blower", "onColor": "#60a5fa" }
