          "config": { "channel": "Flame_Detected", "label": "Detected", "onColor": "#22c55e" }
        },
        {
          "id": "title-status",
          "type": "title",
          "x": 0, "y": 5, "w": 3, "h": 1,
          "config": { "label": "SAFETY SWITCHES", "fontSize": "medium" }
        },
        {
          "id": "led-hilim",
