          "config": { "channel": "High_Limit_OK", "label": "Hi Limit", "onColor": "#22c55e" }
        },
        {
          "id": "led-lowater",
          "type": "led",
          "x": 1, "y": 6, "w": 1, "h": 1,
          "config": { "channel": "Low_Water_OK", "label": "Lo Water", "onColor": "#22c55e" }
        },
        {
          "id": "led-gas-ok",
