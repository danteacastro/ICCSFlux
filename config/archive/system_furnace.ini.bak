# ANALOG INPUTS - MISC FEEDBACK (Slot 8: NI-9239)
# =============================================================================

[channel:AI101]
module = Slot8_AnalogIn
physical_channel = ai0
channel_type = voltage
voltage_range = 10.0
units = A
scale_slope = 10.0
scale_offset = 0.0
description = F1 Heater Current
low_limit = 0
high_limit = 100
high_warning = 80
safety_action = F1_overcurrent
log = true
log_interval_ms = 1000
group = Furnace 1

[channel:AI201]
module = Slot8_AnalogIn
physical_channel = ai1
channel_type = voltage
voltage_range = 10.0
units = A
scale_slope = 10.0
scale_offset = 0.0
description = F2 Heater Current
low_limit = 0
high_limit = 100
high_warning = 80
safety_action = F2_overcurrent
log = true
log_interval_ms = 1000
group = Furnace 2

[channel:AI102]
module = Slot8_AnalogIn
physical_channel = ai2
channel_type = voltage
voltage_range = 10.0
units = %
scale_slope = 10.0
scale_offset = 0.0
description = F1 Heater Power
low_limit = 0
high_limit = 100
log = true
log_interval_ms = 500
group = Furnace 1

[channel:AI202]
module = Slot8_AnalogIn
physical_channel = ai3
channel_type = voltage
voltage_range = 10.0
units = %
scale_slope = 10.0
scale_offset = 0.0
description = F2 Heater Power
low_limit = 0
high_limit = 100
log = true
log_interval_ms = 500
group = Furnace 2

# =============================================================================
# SAFETY ACTIONS - Fail-Safe Philosophy
# =============================================================================

[safety_action:emergency_shutdown]
description = EMERGENCY STOP - Complete System Shutdown
actions = DO101:false, DO201:false, DO102:true, DO202:true, DO003:true, DO004:true
trigger_alarm = true
alarm_message = EMERGENCY STOP ACTIVATED - All heaters disabled, N2 purge active

[safety_action:F1_overtemp]
description = Furnace 1 Software Over-temperature
actions = DO101:false, DO102:true, DO003:true
trigger_alarm = true
alarm_message = FURNACE 1 OVERTEMP - Heater OFF, N2 purge ON

[safety_action:F2_overtemp]
description = Furnace 2 Software Over-temperature
actions = DO201:false, DO202:true, DO003:true
trigger_alarm = true
alarm_message = FURNACE 2 OVERTEMP - Heater OFF, N2 purge ON

[safety_action:F1_overtemp_hw]
description = Furnace 1 Hardware Over-temperature Switch
actions = DO101:false, DO102:true, DO003:true, DO004:true
trigger_alarm = true
alarm_message = FURNACE 1 OVERTEMP (HW) - CRITICAL

[safety_action:F2_overtemp_hw]
description = Furnace 2 Hardware Over-temperature Switch
actions = DO201:false, DO202:true, DO003:true, DO004:true
trigger_alarm = true
alarm_message = FURNACE 2 OVERTEMP (HW) - CRITICAL

[safety_action:F1_door_open]
description = Furnace 1 Door Opened
actions = DO101:false
trigger_alarm = false
alarm_message = F1 door opened - heating paused

[safety_action:F2_door_open]
description = Furnace 2 Door Opened
actions = DO201:false
trigger_alarm = false
alarm_message = F2 door opened - heating paused

[safety_action:F1_low_cooling]
description = Furnace 1 Low Cooling Flow
actions = DO101:false, DO003:true
trigger_alarm = true
alarm_message = F1 LOW COOLING - Heater disabled

[safety_action:F2_low_cooling]
description = Furnace 2 Low Cooling Flow
actions = DO201:false, DO003:true
trigger_alarm = true
alarm_message = F2 LOW COOLING - Heater disabled

[safety_action:low_water_pressure]
description = System Low Water Pressure
actions = DO101:false, DO201:false, DO003:true
trigger_alarm = true
alarm_message = LOW WATER PRESSURE - All heaters disabled

[safety_action:water_flow_loss]
description = Cooling Water Flow Lost
actions = DO101:false, DO201:false, DO102:true, DO202:true, DO003:true, DO004:true
trigger_alarm = true
alarm_message = COOLING FLOW LOST - CRITICAL

[safety_action:low_n2_pressure]
description = Low N2 Supply Pressure
actions = DO003:true
trigger_alarm = true
alarm_message = LOW N2 PRESSURE - Check supply

[safety_action:low_exhaust_flow]
description = Low Exhaust Ventilation
actions = DO101:false, DO201:false, DO003:true
trigger_alarm = true
alarm_message = LOW EXHAUST - Heaters disabled

[safety_action:air_pressure_loss]
description = Compressed Air Lost
actions = DO003:true
trigger_alarm = true
alarm_message = AIR PRESSURE LOST

[safety_action:F1_high_pressure]
description = Furnace 1 High Pressure
actions = DO101:false, DO102:false, DO003:true
trigger_alarm = true
alarm_message = F1 HIGH PRESSURE - Check seal

[safety_action:F2_high_pressure]
description = Furnace 2 High Pressure
