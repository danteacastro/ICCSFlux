[channel:FT003]
module = Slot4_Counters
physical_channel = ctr3
channel_type = voltage
units = L
scale_slope = 100.0
scale_offset = 0
description = Total Water Usage
low_limit = 0
high_limit = 999999
log = true
log_interval_ms = 60000
group = Utilities

# =============================================================================
# VALVE DOSING - FLOW TOTALIZERS (Slot 4: NI-9361)
# =============================================================================
# These counter channels accumulate flow for the valve dosing system.
# In simulation mode, they increment automatically to simulate flow.

[channel:Flow_1]
module = Slot4_Counters
physical_channel = ctr4
channel_type = counter
units = gal
scale_slope = 0.1
scale_offset = 0
description = Valve 1 Flow Totalizer
low_limit = 0
high_limit = 999999
log = true
log_interval_ms = 1000
group = Valve Dosing

[channel:Flow_2]
module = Slot4_Counters
physical_channel = ctr5
channel_type = counter
units = gal
scale_slope = 0.1
scale_offset = 0
description = Valve 2 Flow Totalizer
low_limit = 0
high_limit = 999999
log = true
log_interval_ms = 1000
group = Valve Dosing

[channel:Flow_3]
module = Slot4_Counters
physical_channel = ctr6
channel_type = counter
units = gal
scale_slope = 0.1
scale_offset = 0
description = Valve 3 Flow Totalizer
low_limit = 0
high_limit = 999999
log = true
log_interval_ms = 1000
group = Valve Dosing

# =============================================================================
# DIGITAL INPUTS (Slot 5: NI-9423)
# =============================================================================

[channel:DI001]
module = Slot5_DigitalIn
physical_channel = di0
channel_type = digital_input
invert = true
description = E-Stop (NC)
safety_action = emergency_shutdown
log = true
group = Safety

[channel:DI101]
module = Slot5_DigitalIn
physical_channel = di1
channel_type = digital_input
invert = false
description = F1 Door Closed
safety_action = F1_door_open
log = true
group = Furnace 1

[channel:DI201]
module = Slot5_DigitalIn
physical_channel = di2
channel_type = digital_input
invert = false
description = F2 Door Closed
safety_action = F2_door_open
log = true
group = Furnace 2

[channel:DI102]
module = Slot5_DigitalIn
physical_channel = di3
channel_type = digital_input
invert = true
description = F1 Overtemp Switch
safety_action = F1_overtemp_hw
log = true
group = Furnace 1

[channel:DI202]
module = Slot5_DigitalIn
physical_channel = di4
channel_type = digital_input
invert = true
description = F2 Overtemp Switch
safety_action = F2_overtemp_hw
log = true
group = Furnace 2

[channel:DI002]
module = Slot5_DigitalIn
physical_channel = di5
channel_type = digital_input
invert = false
description = Water Flow OK
safety_action = water_flow_loss
log = true
group = Utilities

[channel:DI003]
module = Slot5_DigitalIn
physical_channel = di6
channel_type = digital_input
invert = false
description = Air Pressure OK
safety_action = air_pressure_loss
log = true
group = Utilities

[channel:DI004]
module = Slot5_DigitalIn
physical_channel = di7
channel_type = digital_input
invert = false
description = Main Power OK
log = true
group = System

