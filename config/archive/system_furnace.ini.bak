log_interval_ms = 2000
group = Utilities

[channel:HT001]
module = Slot3_Analog4to20
physical_channel = ai7
channel_type = current
current_range_ma = 20.0
units = %RH
scale_slope = 6.25
scale_offset = -25
description = Room Humidity
low_limit = 0
high_limit = 100
high_warning = 70
log = true
log_interval_ms = 10000
group = Environment

# =============================================================================
# FLOW METER COUNTERS (Slot 4: NI-9361)
