channel_type = voltage
units = LPM
scale_slope = 5.0
scale_offset = 0
description = F1 Cooling Flow
low_limit = 0
high_limit = 50
low_warning = 5
safety_action = F1_low_cooling
log = true
log_interval_ms = 1000
group = Furnace 1

[channel:FT201]
module = Slot4_Counters
