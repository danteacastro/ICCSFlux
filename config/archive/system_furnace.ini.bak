# =============================================================================
# NISystem Configuration - Dual Furnace Thermal Test Stand
# =============================================================================
# Test System: Two independent furnace chambers for thermal cycling/soak testing
# Safety Philosophy: Fail-safe design - any fault condition disables heaters
# Equipment: 8-slot cDAQ-9189 with full module complement
# =============================================================================

[system]
mqtt_broker = localhost
mqtt_port = 1883
mqtt_base_topic = nisystem
scan_rate_hz = 100
publish_rate_hz = 4
simulation_mode = true
log_directory = ./logs
config_reload_topic = nisystem/config/reload
system_name = Dual Furnace Thermal Test Stand
system_id = TTS-001

# =============================================================================
# CHASSIS
# =============================================================================
[chassis:cDAQ-9189-Main]
type = cDAQ-9189
serial = 01AB23CD
connection = USB
description = Main 8-Slot CompactDAQ Chassis
enabled = true

# =============================================================================
# MODULES (8 slots filled)
# =============================================================================

[module:Slot1_FurnaceTC]
type = NI-9213
chassis = cDAQ-9189-Main
slot = 1
description = Furnace Zone Thermocouples (16ch)
enabled = true

[module:Slot2_DUT_TC]
type = NI-9213
chassis = cDAQ-9189-Main
slot = 2
description = DUT Thermocouples (16ch)
enabled = true

[module:Slot3_Analog4to20]
type = NI-9203
chassis = cDAQ-9189-Main
slot = 3
description = 4-20mA Process Sensors (8ch)
enabled = true

[module:Slot4_Counters]
type = NI-9361
chassis = cDAQ-9189-Main
slot = 4
description = Pulse/Counter Inputs - Flow Meters (8ch)
enabled = true

[module:Slot5_DigitalIn]
type = NI-9423
chassis = cDAQ-9189-Main
slot = 5
description = 24V Digital Inputs (8ch)
enabled = true

[module:Slot6_DigitalOut]
type = NI-9472
chassis = cDAQ-9189-Main
slot = 6
description = 24V Digital Outputs (8ch)
enabled = true

[module:Slot7_AnalogOut]
type = NI-9263
chassis = cDAQ-9189-Main
slot = 7
description = Analog Outputs 0-10V (4ch)
enabled = true

[module:Slot8_AnalogIn]
type = NI-9239
chassis = cDAQ-9189-Main
slot = 8
description = Analog Inputs +/-10V (4ch)
enabled = true

# =============================================================================
# FURNACE 1 - ZONE TEMPERATURES (Slot 1: NI-9213)
# =============================================================================

[channel:TC101]
module = Slot1_FurnaceTC
physical_channel = ai0
channel_type = thermocouple
thermocouple_type = K
units = degC
description = Furnace 1 Zone 1 Top
low_limit = 0
high_limit = 1000
low_warning = 15
high_warning = 950
safety_action = F1_overtemp
log = true
log_interval_ms = 1000
group = Furnace 1

[channel:TC102]
module = Slot1_FurnaceTC
physical_channel = ai1
channel_type = thermocouple
thermocouple_type = K
units = degC
description = Furnace 1 Zone 2 Middle
low_limit = 0
high_limit = 1000
low_warning = 15
high_warning = 950
safety_action = F1_overtemp
log = true
log_interval_ms = 1000
group = Furnace 1

[channel:TC103]
module = Slot1_FurnaceTC
physical_channel = ai2
channel_type = thermocouple
thermocouple_type = K
units = degC
description = Furnace 1 Zone 3 Bottom
low_limit = 0
high_limit = 1000
low_warning = 15
high_warning = 950
safety_action = F1_overtemp
log = true
log_interval_ms = 1000
group = Furnace 1

[channel:TC104]
module = Slot1_FurnaceTC
