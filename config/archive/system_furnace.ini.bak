# =============================================================================
# VALVE DOSING - SOLENOID VALVES (Additional Digital Outputs)
# =============================================================================
# Note: These use virtual channels since Slot6 only has 8 outputs (do0-do7).
# In production, these would need a second digital output module.

[channel:Valve_1]
module = Slot6_DigitalOut
physical_channel = vdo0
channel_type = digital_output
default_state = false
description = Dosing Valve 1
log = true
group = Valve Dosing

[channel:Valve_2]
module = Slot6_DigitalOut
physical_channel = vdo1
channel_type = digital_output
default_state = false
description = Dosing Valve 2
log = true
group = Valve Dosing

[channel:Valve_3]
module = Slot6_DigitalOut
physical_channel = vdo2
channel_type = digital_output
default_state = false
description = Dosing Valve 3
log = true
group = Valve Dosing

# =============================================================================
# ANALOG OUTPUTS (Slot 7: NI-9263)
# =============================================================================

[channel:AO101]
module = Slot7_AnalogOut
physical_channel = ao0
channel_type = analog_output
voltage_range = 10.0
units = degC
scale_slope = 0.01
scale_offset = 0.0
description = F1 Temp Setpoint
default_value = 0.0
low_limit = 0
high_limit = 1000
log = true
group = Furnace 1

[channel:AO201]
module = Slot7_AnalogOut
physical_channel = ao1
channel_type = analog_output
voltage_range = 10.0
units = degC
scale_slope = 0.01
scale_offset = 0.0
description = F2 Temp Setpoint
default_value = 0.0
low_limit = 0
high_limit = 1000
log = true
group = Furnace 2

[channel:AO102]
module = Slot7_AnalogOut
physical_channel = ao2
channel_type = analog_output
voltage_range = 10.0
units = degC/min
scale_slope = 0.1
scale_offset = 0.0
description = F1 Ramp Rate
default_value = 10.0
low_limit = 0
high_limit = 100
log = true
group = Furnace 1

[channel:AO202]
module = Slot7_AnalogOut
physical_channel = ao3
channel_type = analog_output
voltage_range = 10.0
units = degC/min
scale_slope = 0.1
scale_offset = 0.0
description = F2 Ramp Rate
default_value = 10.0
low_limit = 0
high_limit = 100
log = true
group = Furnace 2

