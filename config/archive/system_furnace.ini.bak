# =============================================================================
# 4-20mA PROCESS SENSORS (Slot 3: NI-9203)
# =============================================================================

[channel:PT101]
module = Slot3_Analog4to20
physical_channel = ai0
channel_type = current
current_range_ma = 20.0
units = mbar
four_twenty_scaling = true
eng_units_min = -50
eng_units_max = 1000
description = F1 Chamber Pressure
low_limit = -50
high_limit = 1000
high_warning = 500
safety_action = F1_high_pressure
log = true
log_interval_ms = 1000
group = Furnace 1

[channel:PT201]
module = Slot3_Analog4to20
physical_channel = ai1
channel_type = current
current_range_ma = 20.0
units = mbar
scale_slope = 62.5
scale_offset = -250
description = F2 Chamber Pressure
low_limit = -50
high_limit = 1000
high_warning = 500
safety_action = F2_high_pressure
log = true
log_interval_ms = 1000
group = Furnace 2

[channel:PT001]
module = Slot3_Analog4to20
physical_channel = ai2
channel_type = current
current_range_ma = 20.0
units = psi
scale_slope = 6.25
scale_offset = -25
description = Cooling Water Pressure
low_limit = 0
high_limit = 100
low_warning = 30
safety_action = low_water_pressure
log = true
log_interval_ms = 1000
group = Utilities

[channel:PT002]
module = Slot3_Analog4to20
physical_channel = ai3
channel_type = current
current_range_ma = 20.0
units = psi
scale_slope = 12.5
scale_offset = -50
description = N2 Supply Pressure
low_limit = 0
high_limit = 200
low_warning = 50
safety_action = low_n2_pressure
log = true
log_interval_ms = 5000
group = Utilities

[channel:HT101]
module = Slot3_Analog4to20
physical_channel = ai4
channel_type = current
current_range_ma = 20.0
units = %RH
scale_slope = 6.25
scale_offset = -25
description = F1 Chamber Humidity
low_limit = 0
high_limit = 100
log = true
log_interval_ms = 5000
group = Furnace 1

[channel:HT201]
module = Slot3_Analog4to20
physical_channel = ai5
channel_type = current
current_range_ma = 20.0
units = %RH
scale_slope = 6.25
scale_offset = -25
description = F2 Chamber Humidity
low_limit = 0
high_limit = 100
log = true
log_interval_ms = 5000
group = Furnace 2

[channel:FT001]
module = Slot3_Analog4to20
physical_channel = ai6
channel_type = current
current_range_ma = 20.0
units = CFM
scale_slope = 31.25
scale_offset = -125
description = Exhaust Flow Rate
low_limit = 0
high_limit = 500
low_warning = 100
safety_action = low_exhaust_flow
