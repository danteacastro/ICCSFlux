    "watchdog_timeout_sec": 5,
    "actions": {
      "burner-shutdown": {
        "name": "Burner Emergency Shutdown",
        "description": "Immediate burner shutdown on combustion zone overtemp",
        "outputs": {
          "Burner_Enable": false,
          "Main_Gas_Valve": false,
          "H2_Shutoff_Valve": false,
          "Pilot_Valve": false,
          "Alarm_Horn": true
        },
        "latching": true,
        "priority": 1
      },
      "h2-shutoff": {
        "name": "Hydrogen Emergency Shutoff",
        "description": "Close H2 valve on flashback or overpressure",
        "outputs": {
          "H2_Shutoff_Valve": false,
          "Alarm_Horn": true
        },
        "latching": true,
        "priority": 1
      },
      "h2-leak-emergency": {
        "name": "H2 Leak Emergency",
        "description": "Complete shutdown on hydrogen leak detection",
        "outputs": {
          "Burner_Enable": false,
          "Main_Gas_Valve": false,
          "H2_Shutoff_Valve": false,
          "Pilot_Valve": false,
          "Ignition_Spark": false,
          "Alarm_Horn": true
        },
        "latching": true,
        "priority": 0
      },
      "flame-loss": {
        "name": "Flame Loss Shutdown",
        "description": "Close fuel valves on loss of flame signal",
        "outputs": {
          "Main_Gas_Valve": false,
          "H2_Shutoff_Valve": false,
          "Pilot_Valve": false,
          "Alarm_Horn": true
        },
        "latching": true,
        "priority": 1
      },
      "high-co": {
        "name": "High CO Alarm",
        "description": "Reduce firing rate on high CO emissions",
        "outputs": {
          "Alarm_Horn": true
        },
        "latching": false,
        "priority": 2
      },
      "low-fuel-pressure": {
        "name": "Low Fuel Pressure",
        "description": "Shutdown on loss of fuel pressure",
        "outputs": {
          "Burner_Enable": false,
          "Main_Gas_Valve": false,
          "Pilot_Valve": false
        },
        "latching": true,
        "priority": 1
      },
      "low-water-flow": {
        "name": "Low Water Flow",
        "description": "Reduce firing on low water flow",
        "outputs": {
          "Alarm_Horn": true
        },
        "latching": false,
        "priority": 2
      },
      "water-overheat": {
        "name": "Water Overheat",
        "description": "Reduce firing on high water temperature",
        "outputs": {
          "Alarm_Horn": true
        },
        "latching": false,
        "priority": 2
      },
      "draft-fault": {
        "name": "Draft Fault",
        "description": "Shutdown on furnace pressure fault",
        "outputs": {
          "Burner_Enable": false,
          "Main_Gas_Valve": false,
          "H2_Shutoff_Valve": false,
          "Pilot_Valve": false
        },
        "latching": true,
        "priority": 1
      }
    },
    "interlocks": [
      {
        "name": "Flame Loss Protection",
        "condition": "Flame_Detected == false AND Burner_Enable == true",
        "action": "flame-loss",
        "delay_ms": 2000
      },
      {
        "name": "High Limit Trip",
        "condition": "High_Limit_OK == false",
        "action": "burner-shutdown",
        "delay_ms": 0
      },
      {
        "name": "Low Water Trip",
        "condition": "Low_Water_OK == false",
        "action": "burner-shutdown",
        "delay_ms": 0
      },
      {
        "name": "E-Stop Trip",
        "condition": "E_Stop_OK == false",
        "action": "h2-leak-emergency",
        "delay_ms": 0
      },
      {
        "name": "Door Interlock",
        "condition": "Door_Interlock_OK == false AND Burner_Enable == true",
        "action": "burner-shutdown",
        "delay_ms": 0
      }
    ]
  },
  "scripts": {
